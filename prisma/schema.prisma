generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Page {
  id            String         @id @default(cuid())
  slug          String         @unique
  type          String         @default("SERVICE") // "SERVICE", "BLOG", "PAGE", "BIOGRAPHY"
  titleInternal String
  seoScore      Int            @default(0)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @default(now()) @updatedAt
  blocks        ContentBlock[]
  faqs          Faq[]
  seoMeta       SeoMeta[]
  service       Service?
}

model ContentBlock {
  id            String        @id @default(cuid())
  pageId        String
  componentType String
  sortOrder     Int           @default(0)
  isActive      Boolean       @default(true)
  schemaDef     String        @default("{}")
  createdAt     DateTime      @default(now())
  page          Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  translations  Translation[]
}

model Translation {
  id          String       @id @default(cuid())
  blockId     String
  locale      String
  contentData String       @default("{}")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @default(now()) @updatedAt
  block       ContentBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@unique([blockId, locale])
}

model ClickEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  fromPage  String
  toUrl     String
  label     String
  category  String   @default("outbound")
  referer   String?
  refDomain String?
  ua        String?
  device    String?
  browser   String?
  ip        String?
  country   String?
  city      String?
}

model PageView {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  page      String
  referer   String?
  refDomain String?
  country   String?
  city      String?
  device    String?
  ip        String?
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model appointments {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String    @db.VarChar(255)
  phone             String    @db.VarChar(50)
  email             String?   @db.VarChar(255)
  message           String?
  service_requested String?   @db.VarChar(255)
  status            String?   @default("pending") @db.VarChar(50)
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model content_entries {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type            String    @db.VarChar(50)
  slug            String?   @db.VarChar(255)
  image_url       String?
  visible_locales String[]  @default(["tr", "en", "ru", "ar", "fr", "de", "cin"])
  translations    Json?     @default("{}")
  created_at      DateTime? @default(now()) @db.Timestamptz(6)
  updated_at      DateTime? @default(now()) @db.Timestamptz(6)

  @@index([type], map: "idx_content_entries_type")
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model special_events {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  event_name         String    @db.VarChar(255)
  start_date         DateTime  @db.Date
  end_date           DateTime  @db.Date
  theme_class        String?   @db.VarChar(100)
  popup_translations Json?     @default("{}")
  is_active          Boolean?  @default(true)
  created_at         DateTime? @default(now()) @db.Timestamptz(6)
}

model SeoMeta {
  id              String  @id @default(cuid())
  pageId          String
  locale          String
  metaTitle       String
  metaDescription String
  ogImage         String?
  canonicalUrl    String?
  robots          String  @default("index,follow")
  keywords        String?
  structuredData  String?
  shortAnswer     String?
  faqJson         String?
  page            Page    @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@unique([pageId, locale])
}

model Redirect {
  id         String   @id @default(cuid())
  fromPath   String   @unique
  toPath     String
  statusCode Int      @default(301)
  locale     String?
  hitCount   Int      @default(0)
  createdAt  DateTime @default(now())
}

model Service {
  id         String  @id @default(cuid())
  pageId     String  @unique
  category   String
  iconKey    String?
  priceFrom  Int?
  duration   String?
  anesthesia String?
  recovery   String?
  sortOrder  Int     @default(0)
  page       Page    @relation(fields: [pageId], references: [id])
}

model Faq {
  id        String  @id @default(cuid())
  pageId    String?
  locale    String
  question  String
  answer    String
  sortOrder Int     @default(0)
  page      Page?   @relation(fields: [pageId], references: [id])
}

model BeforeAfter {
  id        String  @id @default(cuid())
  serviceId String?
  beforeUrl String
  afterUrl  String
  caption   String?
  consent   Boolean @default(false)
  isPublic  Boolean @default(false)
  createdAt DateTime @default(now())
}

model Testimonial {
  id        String   @id @default(cuid())
  author    String
  rating    Int
  locale    String
  text      String
  source    String?
  approved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Media {
  id         String   @id @default(cuid())
  url        String   @unique
  altTr      String?
  altEn      String?
  altAr      String?
  altRu      String?
  focalX     Float    @default(0.5)
  focalY     Float    @default(0.5)
  width      Int?
  height     Int?
  mime       String?
  uploadedAt DateTime @default(now())
}
