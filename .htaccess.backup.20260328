# Modern SEO-Friendly URL Routing
# Prof. Dr. Gökçe Özel Clinic Website
# Updated: 2026-02-11

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Force HTTPS (recommended for SEO)
    RewriteCond %{HTTPS} off
    RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # ============================================
    # LANGUAGE-BASED ROUTING
    # Pattern: /[lang]/[category]/[slug]
    # LANGUAGE-BASED ROUTING
    # Pattern: /[lang]/[category]/[slug]
    # ============================================

    # Homepage with language
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/?$ index.php?LN=$1 [L,QSA]

    # Services listing: /en/services
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/services/?$ hizmetler.php?LN=$1 [L,QSA]

    # Category listing: /en/category/slug
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/category/([a-zA-Z0-9-]+)/?$ hizmetler.php?LN=$1&slug=$2 [L,QSA]

    # Service detail: /en/services/rhinoplasty
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/services/([a-zA-Z0-9-]+)/?$ hizmetdetay.php?LN=$1&slug=$2 [L,QSA]

    # Blog listing: /en/blog
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/blog/?$ blog.php?LN=$1 [L,QSA]

    # Blog detail: /en/blog/facial-aesthetics-trends-2024
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/blog/([a-zA-Z0-9-]+)/?$ blogdetay.php?LN=$1&slug=$2 [L,QSA]

    # Contact: /en/contact
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/contact/?$ iletisim.php?LN=$1 [L,QSA]

    # Appointment: /en/appointment
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/appointment/?$ randevu.php?LN=$1 [L,QSA]

    # Gallery: /en/gallery
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/gallery/?$ fotogaleri.php?LN=$1 [L,QSA]
    
    # Gallery Category: /en/gallery/burun-estetigi
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/gallery/([a-zA-Z0-9-]+)/?$ fotogaleri.php?LN=$1&slug=$2 [L,QSA]

    # Corporate/About: /en/about
    RewriteRule ^(tr|en|ru|ar|de|fr|cin)/about/?$ kurumsal.php?LN=$1 [L,QSA]

    # Default language redirect (Turkish)
    RewriteRule ^$ /tr/ [R=302,L]

    # ============================================
    # BACKWARD COMPATIBILITY
    # Redirect old URLs to new SEO-friendly format
    # ============================================

    # Old service detail URLs: hizmetdetay.php?LN=EN&detay=ID
    RewriteCond %{QUERY_STRING} LN=([^&]+)
    RewriteCond %{QUERY_STRING} detay=([^&]+)
    RewriteRule ^hizmetdetay\.php$ /%1/services/%2? [R=301,L]

    # Old blog detail URLs: blogdetay.php?LN=EN&detay=ID
    RewriteCond %{QUERY_STRING} LN=([^&]+)
    RewriteCond %{QUERY_STRING} detay=([^&]+)
    RewriteRule ^blogdetay\.php$ /%1/blog/%2? [R=301,L]

    # ============================================
    # SITEMAP ROUTING
    # ============================================
    RewriteRule ^sitemap\.xml$ sitemap.xml.php [L]

    # ============================================
    # SECURITY
    # Prevent access to sensitive files
    # ============================================
    <FilesMatch "^(baglan|veritabanifonksiyonlari|baglantilar_fonksiyonlar)\.php$">
        Require all denied
    </FilesMatch>

    # Protect .htaccess and other hidden files
    <FilesMatch "^\.">
        Require all denied
    </FilesMatch>

    # Protect sensitive file types
    <FilesMatch "\.(sh|sql|log|ini|conf|bak)$">
        Require all denied
    </FilesMatch>
</IfModule>

# ============================================
# PERFORMANCE OPTIMIZATION
# Browser caching for static assets
# ============================================
<IfModule mod_expires.c>
    ExpiresActive On

    # Images
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType image/x-icon "access plus 1 year"

    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType text/javascript "access plus 1 month"

    # Fonts
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"

    # HTML
    ExpiresByType text/html "access plus 0 seconds"
</IfModule>

# ============================================
# COMPRESSION
# Gzip compression for text-based files
# ============================================
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE text/javascript
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/json
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
</IfModule>

# ============================================
# SECURITY HEADERS
# ============================================
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"

    # XSS Protection
    Header always set X-XSS-Protection "1; mode=block"

    # Content Type Options
    Header always set X-Content-Type-Options "nosniff"

    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ============================================
# ERROR DOCUMENTS
# ============================================
ErrorDocument 404 /404.php
ErrorDocument 500 /document_errors/50x.html

# Disable directory listing
Options -Indexes

# Follow symbolic links
Options +FollowSymLinks
